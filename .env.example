# Database
DATABASE_URL=postgresql://dev:devpassword@localhost:5432/portfolio

# Security
JWT_SECRET=your-secret-key-at-least-32-characters-long

# AI Providers (cascade: Groq → Gemini → OpenRouter)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# API Proxy
ALLOWED_API_DOMAINS=api.github.com,jsonplaceholder.typicode.com,httpbin.org
API_RATE_LIMIT=30
API_TIMEOUT=30

# Filesystem
WORKSPACE_ROOT=./data/workspace
MAX_FILE_SIZE=10485760
ALLOWED_EXTENSIONS=.md,.txt,.csv,.json,.yaml,.yml,.html,.xml

# Audit
AUDIT_LOG_DIR=./data/audit_logs

# Logging
LOG_LEVEL=INFO
